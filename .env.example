# ============================
# BountyChain — Environment Variables
# ============================
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real secrets.

# Algorand Network (localnet | testnet)
ALGORAND_NETWORK=localnet

# Algod connection (LocalNet defaults)
ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGOD_SERVER=http://localhost
ALGOD_PORT=4001

# Indexer connection (LocalNet defaults)
INDEXER_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
INDEXER_SERVER=http://localhost
INDEXER_PORT=8980

# Server wallet (backend signer — the account that deploys and manages escrow contracts)
# For LocalNet: use a funded LocalNet account mnemonic (25 words, space-separated)
# For TestNet: fund via https://bank.testnet.algorand.network/
SERVER_WALLET_MNEMONIC=

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/bountychain

# Express backend port
PORT=4000

# Gemini API key (for AI verification in Phase 4)
GEMINI_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
